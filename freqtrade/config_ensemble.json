{
    "max_open_trades": 9,
    "stake_amount": "unlimited",
    "stake_currency": "USDT",
    "tradable_balance_ratio": 0.99,
    "fiat_display_currency": "USD",
    "dry_run": true,
    "dry_run_wallet": 10000,
    "cancel_open_orders_on_exit": false,
    "trading_mode": "futures",
    "margin_mode": "isolated",
    "unfilledtimeout": {
        "entry": 10,
        "exit": 10,
        "exit_timeout_count": 0,
        "unit": "minutes"
    },
    "entry_pricing": {
        "price_side": "same",
        "use_order_book": false
    },
    "exit_pricing": {
        "price_side": "same",
        "use_order_book": false
    },
    "exchange": {
        "name": "binance",
        "key": "YOUR_API_KEY",
        "secret": "YOUR_SECRET",
        "ccxt_config": {
            "enableRateLimit": true,
            "options": {
                "defaultType": "future"
            }
        },
        "ccxt_async_config": {
            "enableRateLimit": true,
            "rateLimit": 200
        },
        "pair_whitelist": [
            "BTC/USDT"
        ],
        "pair_blacklist": []
    },
    "pairlists": [
        {
            "method": "StaticPairList",
            "number_assets": 9,
            "sort_key": "quoteVolume",
            "min_value": 0,
            "refresh_period": 1800
        }
    ],
    "telegram": {
        "enabled": false,
        "token": "",
        "chat_id": "",
        "notification_settings": {
            "status": "silent",
            "warning": "on",
            "startup": "off",
            "entry": "silent",
            "exit": "on",
            "entry_fill": "off",
            "exit_fill": "on",
            "protection_trigger": "off",
            "protection_global_trigger": "on"
        },
        "reload": true
    },
    "api_server": {
        "enabled": true,
        "listen_ip_address": "0.0.0.0",
        "listen_port": 8080,
        "verbosity": "info",
        "enable_openapi": false,
        "jwt_secret_key": "change_this_to_a_random_string_in_production",
        "ws_token": "aiquant_ws_token_change_me",
        "CORS_origins": [],
        "username": "aiquant",
        "password": "aiquant_password_change_me"
    },
    "bot_name": "AiQuantBot",
    "initial_state": "running",
    "force_entry_enable": false,
    "internals": {
        "process_throttle_secs": 5
    }
}
